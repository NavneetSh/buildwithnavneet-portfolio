---
import { profile, proofPoints, expertise, projects } from '../data/portfolio';
---
<!doctype html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width"><meta name="description" content={`Portfolio of ${profile.name} — ${profile.role}.`}><title>{profile.name} | {profile.role}</title></head><body>
<header><nav class="shell"><a class="brand" href="/"><span>N</span><b>{profile.name}</b></a><div class="navlinks"><a href="#work">Work</a><a href="#expertise">Expertise</a><a href="#resume">Resume</a><a href={profile.blogUrl}>Blog ↗</a></div></nav></header>
<main>
<section class="hero shell"><div><p class="eyebrow">{profile.eyebrow}</p><h1>I build the platforms<br><em>behind modern technology.</em></h1><p class="lead">{profile.intro}</p><div class="actions"><a class="primary" href="#work">Explore my work <span>↘</span></a><a class="secondary" href={profile.blogUrl}>Read my writing <span>→</span></a></div><div class="proof">{proofPoints.map((item)=><span><b>{item.value}</b>{item.label}</span>)}</div></div><div class="visual" aria-hidden="true"><div class="orbit one"></div><div class="orbit two"></div><div class="core">N<span>S</span></div><div class="card c1"><small>ARCHITECTURE</small><b>Systems that scale</b></div><div class="card c2"><small>PHILOSOPHY</small><b>Learn. Build. Share.</b></div></div></section>
<section id="expertise" class="section shell"><div class="heading"><div><p class="eyebrow">WHAT I WORK ON</p><h2>Engineering across the stack.</h2></div><p>I work where infrastructure, developer experience and emerging AI systems meet.</p></div><div class="grid">{expertise.map((item)=><article class="expert"><span class="plus">+</span><h3>{item.title}</h3><p>{item.description}</p><small>{item.tags}</small></article>)}</div></section>
<section id="work" class="work"><div class="shell"><div class="heading light"><div><p class="eyebrow">SELECTED WORK</p><h2>Portfolio & case studies.</h2></div><p>Architecture, automation and platform projects focused on solving real engineering problems.</p></div><div class="grid">{projects.map((project)=><article class="project"><div class="projecttop"><span>{project.number}</span><small>CASE STUDY</small></div><div class="art">{project.number}</div><h3>{project.title}</h3><p>{project.description}</p><small>{project.tags}</small></article>)}</div><p class="note">More case studies coming as I document the systems I've built and the lessons behind them.</p></div></section>
<section id="resume" class="resume"><div class="shell resume-inner"><div><p class="eyebrow">TAKE IT WITH YOU</p><h2>Prefer the complete story<br><em>in one document?</em></h2><p>Download my PDF resume for a concise reference to my experience, architecture background, technical capabilities and selected work.</p></div><a class="download" href={profile.resumeUrl} download><span><small>PDF DOCUMENT</small><b>Download my resume</b></span><strong>↓</strong></a></div></section>
<section class="about shell"><p class="eyebrow">ABOUT</p><div><h2>Learning the future<br>by <em>building it.</em></h2><p>{profile.about}</p></div><a href={profile.blogUrl}>Visit BuildWithNavneet →</a></section>
</main><footer class="shell"><span>© {new Date().getFullYear()} {profile.name}</span><span>Cloud · DevOps · AI Infrastructure</span></footer>
</body></html>
<style is:global>
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:#fff;color:#0f172a;font-family:Inter,ui-sans-serif,system-ui,-apple-system,sans-serif}.shell{width:min(1180px,calc(100% - 48px));margin:auto}header{position:sticky;top:0;z-index:10;background:rgba(255,255,255,.9);backdrop-filter:blur(16px);border-bottom:1px solid #e2e8f0}nav{height:72px;display:flex;align-items:center;justify-content:space-between}.brand{display:flex;align-items:center;gap:10px;color:#111827;text-decoration:none;font-size:14px}.brand span{width:34px;height:34px;border-radius:50%;display:grid;place-items:center;background:#111827;color:#fff;font:700 17px Georgia}.navlinks{display:flex;gap:28px}.navlinks a{color:#64748b;text-decoration:none;font-size:13px;font-weight:650}.navlinks a:hover{color:#4f46e5}.hero{min-height:720px;display:grid;grid-template-columns:1.2fr .8fr;align-items:center;gap:70px;padding-top:70px;padding-bottom:80px}.eyebrow{font:700 11px ui-monospace,SFMono-Regular,monospace;letter-spacing:.16em;color:#64748b;margin:0 0 24px}.eyebrow:before{content:'';display:inline-block;width:28px;height:1px;background:#4f46e5;vertical-align:middle;margin-right:10px}.hero h1,.heading h2,.about h2,.resume h2{font-family:Georgia,'Times New Roman',serif;letter-spacing:-.045em}.hero h1{font-size:clamp(52px,6.2vw,86px);line-height:.98;margin:0;font-weight:500}.hero h1 em,.about h2 em,.resume h2 em{font-weight:400;color:#4f46e5}.lead{font-size:19px;line-height:1.7;max-width:680px;color:#64748b;margin:32px 0}.actions{display:flex;gap:12px;flex-wrap:wrap}.actions a{display:inline-flex;align-items:center;gap:30px;padding:15px 20px;border-radius:6px;text-decoration:none;font-size:14px;font-weight:700}.primary{background:#4f46e5;color:#fff}.secondary{border:1px solid #cbd5e1;color:#334155}.proof{display:flex;gap:30px;margin-top:54px;padding-top:24px;border-top:1px solid #e2e8f0;font-size:12px;color:#94a3b8}.proof span{display:flex;flex-direction:column;gap:3px}.proof b{color:#334155;font-size:13px}.visual{height:500px;position:relative;display:grid;place-items:center;background:radial-gradient(circle,rgba(79,70,229,.12),transparent 56%)}.orbit{position:absolute;border:1px solid #cbd5e1;border-radius:50%}.one{width:360px;height:360px}.two{width:240px;height:240px}.core{width:145px;height:145px;border-radius:50%;background:#111827;color:white;display:grid;place-items:center;font:500 38px Georgia;box-shadow:0 30px 80px rgba(15,23,42,.25)}.core span{color:#818cf8}.card{position:absolute;background:rgba(255,255,255,.92);border:1px solid #e2e8f0;padding:16px 18px;box-shadow:0 18px 50px rgba(15,23,42,.1);display:flex;flex-direction:column}.card small{font-size:9px;letter-spacing:.14em;color:#94a3b8}.card b{font-size:13px}.c1{top:90px;right:0}.c2{bottom:85px;left:0}.section{padding:110px 0 130px}.heading{display:flex;justify-content:space-between;align-items:end;gap:50px;margin-bottom:55px}.heading h2{font-size:clamp(40px,5vw,62px);font-weight:500;margin:0}.heading>p{max-width:420px;color:#64748b;line-height:1.7}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.expert{border:1px solid #e2e8f0;padding:34px;min-height:300px;transition:.25s}.expert:hover{transform:translateY(-5px);box-shadow:0 24px 60px rgba(15,23,42,.08)}.plus{font-size:30px;color:#4f46e5;display:block;margin-bottom:48px}.expert h3,.project h3{font-size:21px;margin:0 0 12px}.expert p,.project p{font-size:14px;line-height:1.7;color:#64748b}.expert small,.project small{font:600 10px ui-monospace,monospace;color:#64748b}.work{background:#0b1120;padding:120px 0;color:#fff}.light h2{color:#fff}.light>p,.light .eyebrow{color:#94a3b8}.project{border:1px solid #253047;padding:24px;background:#101827}.projecttop{display:flex;justify-content:space-between;color:#64748b}.projecttop small{color:#818cf8}.art{height:180px;margin:22px 0 28px;background:linear-gradient(135deg,#172033,#111827);display:grid;place-items:center;font:500 100px Georgia;color:#202c43}.project h3{color:#fff}.project p{color:#94a3b8}.note{text-align:center;color:#64748b;font-size:13px;margin:38px 0 0}.resume{background:#f5f7ff;padding:100px 0;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0}.resume-inner{display:grid;grid-template-columns:1.3fr .7fr;align-items:center;gap:80px}.resume h2{font-size:clamp(42px,5vw,64px);line-height:1.03;font-weight:500;margin:0 0 24px}.resume p{max-width:650px;color:#64748b;font-size:16px;line-height:1.8}.download{background:#fff;border:1px solid #dbe2f0;padding:28px;display:flex;align-items:center;justify-content:space-between;text-decoration:none;color:#0f172a;box-shadow:0 18px 50px rgba(15,23,42,.08);transition:.25s}.download:hover{transform:translateY(-4px);border-color:#4f46e5}.download span{display:flex;flex-direction:column;gap:7px}.download small{font:700 9px ui-monospace,monospace;letter-spacing:.14em;color:#818cf8}.download b{font-size:16px}.download strong{font-size:30px;color:#4f46e5}.about{padding:130px 0;display:grid;grid-template-columns:.5fr 1.4fr .5fr;gap:40px;align-items:start}.about h2{font-size:clamp(44px,5vw,66px);line-height:1.05;font-weight:500;margin:0}.about div p{max-width:650px;color:#64748b;font-size:17px;line-height:1.8}.about>a{color:#334155;text-decoration:none;font-weight:700;font-size:13px;justify-self:end;border-bottom:1px solid #cbd5e1;padding-bottom:8px}footer{border-top:1px solid #e2e8f0;padding:30px 0 45px;display:flex;justify-content:space-between;color:#94a3b8;font-size:12px}@media(max-width:900px){.hero{grid-template-columns:1fr;min-height:auto;padding-top:100px}.visual{height:380px}.grid,.resume-inner{grid-template-columns:1fr}.heading{align-items:start;flex-direction:column}.about{grid-template-columns:1fr}.about>a{justify-self:start}.proof{flex-wrap:wrap}}@media(max-width:600px){.shell{width:calc(100% - 28px)}.navlinks{gap:10px}.navlinks a{font-size:10px}.hero{padding-top:70px;gap:20px}.hero h1{font-size:48px}.visual{height:320px}.one{width:280px;height:280px}.two{width:190px;height:190px}.core{width:120px;height:120px}.card{display:none}.section,.work,.about,.resume{padding-top:80px;padding-bottom:80px}.expert{min-height:auto}footer{gap:20px;flex-direction:column}}
</style>