---
import { profile, proofPoints, expertise, projects, companies, certifications, collaboration } from '../data/portfolio';
const emailHref = `mailto:${profile.email}?subject=Let%27s%20work%20together`;
---
<!doctype html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width"><meta name="description" content={`${profile.name} — ${profile.role}. Cloud, platform engineering and AI infrastructure.`}><title>{profile.name} | {profile.role}</title></head><body id="top">
<header><nav class="shell"><a class="brand" href="#top"><span>N</span><b>{profile.name}</b></a><div class="navlinks"><a href="#services">Work together</a><a href="#work">Work</a><a href="#credentials">Credentials</a><a href="#resume">Resume</a><a href="#contact">Contact</a><a href={profile.blogUrl}>Blog ↗</a></div></nav></header>
<main>
<section class="hero shell"><div><p class="eyebrow">{profile.eyebrow}</p><h1>{profile.headline}</h1><p class="lead">{profile.intro}</p><div class="actions"><a class="primary" href={emailHref}>Email me <span>↗</span></a><a class="secondary" href="#work">Explore my work <span>→</span></a></div><div class="proof">{proofPoints.map((item)=><span><b>{item.value}</b>{item.label}</span>)}</div></div><div class="visual"><div class="orbit one"></div><div class="orbit two"></div><div class="portrait-wrap"><img src="/images/navneet-profile.jpg" alt="Navneet Sharma, Cloud and AI Platform Architect" /></div><div class="card c1"><small>ARCHITECTURE</small><b>Systems that scale</b></div><div class="card c2"><small>DIRECTION</small><b>Cloud → AI platforms</b></div></div></section>
<section class="trust"><div class="shell"><p>EXPERIENCE SHAPED ACROSS</p><div class="companies">{companies.map((company,index)=><div class={`company company-${index+1}`}><strong>{company.name}</strong><small>{company.context}</small></div>)}</div></div></section>
<section id="services" class="section shell"><div class="heading"><div><p class="eyebrow">WAYS I CAN HELP</p><h2>Senior technical thinking,<br>applied to hard problems.</h2></div><p>For teams that need clarity before complexity: architecture decisions, platform foundations and hands-on technical collaboration.</p></div><div class="grid">{collaboration.map((item,index)=><article class="expert"><span class="plus">0{index+1}</span><h3>{item.title}</h3><p>{item.description}</p><a href={emailHref}>START A CONVERSATION →</a></article>)}</div></section>
<section class="section soft shell"><div class="heading"><div><p class="eyebrow">TECHNICAL DEPTH</p><h2>Engineering across the stack.</h2></div><p>I work where infrastructure, developer experience and emerging AI systems meet.</p></div><div class="grid">{expertise.map((item)=><article class="expert"><span class="plus">+</span><h3>{item.title}</h3><p>{item.description}</p><small>{item.tags}</small></article>)}</div></section>
<section id="work" class="work"><div class="shell"><div class="heading light"><div><p class="eyebrow">SELECTED WORK</p><h2>Architecture with a reason.</h2></div><p>Platform and infrastructure work framed around the problem, the decisions and the engineering outcome.</p></div><div class="grid">{projects.map((project)=><article class="project"><div class="projecttop"><span>{project.number}</span><small>CASE STUDY</small></div><div class="art">{project.number}</div><h3>{project.title}</h3><p>{project.description}</p><small>{project.tags}</small></article>)}</div></div></section>
<section id="credentials" class="credentials"><div class="shell credential-layout"><div><p class="eyebrow">MICROSOFT CREDENTIALS</p><h2>Validated foundations.<br><em>Applied in practice.</em></h2><p>Credentials across architecture, cloud operations, security and DevOps reinforce a broader career built around production platforms.</p></div><div class="cert-cloud">{certifications.map((cert,index)=><article class={`cert cert-${index+1}`}><div class="ms"><i></i><i></i><i></i><i></i></div><small>{cert.focus}</small><strong>{cert.code}</strong><span>{cert.label}</span></article>)}</div></div></section>
<section id="resume" class="resume"><div class="shell resume-inner"><div><p class="eyebrow">PUBLIC PROFESSIONAL PROFILE</p><h2>Take the complete story<br><em>with you.</em></h2><p>Download my privacy-conscious PDF resume for a concise reference to my architecture background, technical capabilities and selected experience.</p></div><a class="download" href={profile.resumeUrl} download><span><small>PDF DOCUMENT</small><b>Download public resume</b></span><strong>↓</strong></a></div></section>
<section class="about shell"><p class="eyebrow">ABOUT</p><div><h2>Learning the future<br>by <em>building it.</em></h2><p>{profile.about}</p></div><a href={profile.blogUrl}>Read BuildWithNavneet →</a></section>
<section id="contact" class="contact"><div class="shell"><p class="eyebrow">LET'S CONNECT</p><h2>Have a difficult platform problem<br>or an ambitious idea?</h2><p class="contact-lead">I’m open to architecture conversations, technical collaborations and selected opportunities.</p><div class="contact-grid"><a href={emailHref}><small>EMAIL</small><strong>{profile.email}</strong><span>Start a conversation ↗</span></a><a href={profile.blogUrl}><small>BLOG</small><strong>BuildWithNavneet</strong><span>Read what I’m learning and building ↗</span></a><a href={profile.portfolioUrl}><small>PORTFOLIO</small><strong>Professional profile</strong><span>Share this portfolio ↗</span></a></div></div></section>
</main><footer class="shell"><span>© {new Date().getFullYear()} {profile.name}</span><div><a href={emailHref}>{profile.email}</a><a href={profile.blogUrl}>Blog</a><a href={profile.portfolioUrl}>Portfolio</a></div></footer><a class="back-top" href="#top" aria-label="Back to top">↑<span>TOP</span></a>
</body></html>
<style is:global>
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;color:#0f172a;font-family:Inter,ui-sans-serif,system-ui,-apple-system,sans-serif}.shell{width:min(1180px,calc(100% - 48px));margin:auto}header{position:sticky;top:0;z-index:20;background:#fffffff0;backdrop-filter:blur(18px);border-bottom:1px solid #e2e8f0}nav{height:72px;display:flex;align-items:center;justify-content:space-between}.brand{display:flex;align-items:center;gap:10px;color:#111827;text-decoration:none}.brand span{width:34px;height:34px;border-radius:50%;display:grid;place-items:center;background:#111827;color:#fff;font:700 17px Georgia}.navlinks{display:flex;gap:20px}.navlinks a,footer a{color:#64748b;text-decoration:none;font-size:12px;font-weight:700}.hero{min-height:760px;display:grid;grid-template-columns:1.12fr .88fr;align-items:center;gap:60px;padding:75px 0 90px}.eyebrow{font:700 10px ui-monospace,monospace;letter-spacing:.17em;color:#64748b;margin:0 0 24px}.eyebrow:before{content:'';display:inline-block;width:28px;height:1px;background:#4f46e5;vertical-align:middle;margin-right:10px}.hero h1,.heading h2,.about h2,.resume h2,.credentials h2,.contact h2{font-family:Georgia,serif;letter-spacing:-.045em}.hero h1{font-size:clamp(54px,6.5vw,88px);line-height:.97;margin:0;font-weight:500}.lead{font-size:18px;line-height:1.75;color:#64748b;margin:32px 0}.actions{display:flex;gap:12px;flex-wrap:wrap}.actions a{padding:15px 20px;border-radius:14px;text-decoration:none;font-size:13px;font-weight:750}.primary{background:#4f46e5;color:#fff}.secondary{border:1px solid #cbd5e1;color:#334155}.proof{display:flex;gap:34px;margin-top:52px;padding-top:24px;border-top:1px solid #e2e8f0;font-size:11px;color:#94a3b8}.proof span{display:flex;flex-direction:column}.proof b{color:#334155;font-size:14px}.visual{height:560px;position:relative;display:grid;place-items:center;background:radial-gradient(circle,#4f46e52b,transparent 60%);isolation:isolate}.orbit{position:absolute;border:1px solid #cbd5e1;border-radius:50%;animation:spin 22s linear infinite}.one{width:440px;height:440px}.two{width:345px;height:345px;animation-direction:reverse}.portrait-wrap{position:relative;z-index:2;width:310px;height:410px;border-radius:155px 155px 42px 42px;overflow:hidden;box-shadow:0 35px 90px #0f172a47;animation:portraitFloat 6s ease-in-out infinite;background:#111827}.portrait-wrap img{width:100%;height:100%;object-fit:cover;object-position:50% 16%;transform:scale(1.01)}.card{position:absolute;z-index:3;background:#fffffff0;backdrop-filter:blur(12px);border:1px solid #e2e8f0;padding:16px 18px;border-radius:16px;box-shadow:0 18px 50px #0f172a1f;display:flex;flex-direction:column;animation:softFloat 5s ease-in-out infinite}.card small{font-size:8px;color:#94a3b8}.card b{font-size:12px}.c1{top:82px;right:0}.c2{bottom:72px;left:0;animation-delay:-2.5s}.trust{border-block:1px solid #e2e8f0;padding:38px 0;background:#fafafa;overflow:hidden}.trust p{text-align:center;font:700 9px ui-monospace,monospace;letter-spacing:.2em;color:#94a3b8}.companies{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;max-width:940px;margin:auto}.company{text-align:center;background:#fff;border:1px solid #e2e8f0;border-radius:20px;padding:22px;box-shadow:0 16px 40px #0f172a0d;animation:companyFloat 6s ease-in-out infinite}.company-2{animation-delay:-2s}.company-3{animation-delay:-4s}.company strong,.company small{display:block}.company strong{font-size:22px}.company small{font-size:10px;color:#94a3b8;margin-top:4px}.section,.credentials,.resume,.about,.contact{padding:110px 0}.soft{background:#fafbff}.heading{display:flex;justify-content:space-between;align-items:end;gap:50px;margin-bottom:55px}.heading h2,.credentials h2,.resume h2,.about h2,.contact h2{font-size:clamp(40px,5vw,64px);font-weight:500;margin:0}.heading>p,.credentials p,.resume p,.about p,.contact-lead{max-width:650px;color:#64748b;line-height:1.8}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.expert,.project{padding:34px;border:1px solid #e2e8f0;border-radius:24px}.expert{min-height:290px;box-shadow:0 16px 45px #0f172a0a}.expert a{font:700 9px ui-monospace,monospace;color:#4f46e5;text-decoration:none}.plus{display:block;margin-bottom:55px;color:#4f46e5}.work{background:#0b1120;padding:120px 0;color:#fff}.project{border-color:#253047;background:#101827}.project p{color:#94a3b8;line-height:1.7}.projecttop{display:flex;justify-content:space-between}.art{height:180px;margin:22px 0;background:#172033;border-radius:18px;display:grid;place-items:center;font:500 100px Georgia;color:#202c43}.credential-layout,.resume-inner{display:grid;grid-template-columns:.8fr 1.2fr;gap:70px;align-items:center}.credentials{overflow:hidden}.cert-cloud{height:470px;position:relative}.cert{position:absolute;width:245px;background:#fff;border:1px solid #e2e8f0;border-radius:22px;padding:24px;box-shadow:0 24px 70px #0f172a1a;display:flex;flex-direction:column;animation:certFloat 6s ease-in-out infinite}.cert-1{top:0;left:4%;transform:rotate(-4deg)}.cert-2{top:45px;right:2%;transform:rotate(4deg);animation-delay:-1.5s}.cert-3{bottom:20px;left:0;transform:rotate(3deg);animation-delay:-3s}.cert-4{bottom:0;right:8%;transform:rotate(-3deg);animation-delay:-4.5s}.cert strong{font-size:31px}.cert span,.cert small{color:#64748b}.ms{width:28px;height:28px;display:grid;grid-template-columns:1fr 1fr;gap:2px}.ms i{background:#4f46e5;border-radius:2px}.resume{background:#eef2ff}.download{background:#fff;border:1px solid #dbe2f0;border-radius:22px;padding:28px;display:flex;justify-content:space-between;text-decoration:none;color:#0f172a;box-shadow:0 18px 50px #0f172a12}.about{display:grid;grid-template-columns:.5fr 1.4fr .5fr;gap:40px}.about>a{color:#334155}.contact{background:#0b1120;color:#fff;text-align:center}.contact .eyebrow{color:#94a3b8}.contact h2{font-size:clamp(46px,6vw,76px)}.contact-lead{margin:24px auto 48px}.contact-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;text-align:left}.contact-grid a{background:#101827;border:1px solid #253047;border-radius:22px;padding:28px;color:#fff;text-decoration:none;display:flex;flex-direction:column;gap:10px;transition:.25s}.contact-grid a:hover{transform:translateY(-5px);border-color:#818cf8}.contact-grid small{color:#818cf8;font:700 9px ui-monospace,monospace}.contact-grid strong{font-size:17px}.contact-grid span{color:#94a3b8;font-size:12px}footer{padding:30px 0 45px;display:flex;justify-content:space-between;color:#94a3b8;font-size:12px}footer div{display:flex;gap:20px}.back-top{position:fixed;right:24px;bottom:24px;z-index:30;width:58px;height:58px;border-radius:50%;background:#4f46e5;color:#fff;text-decoration:none;display:flex;flex-direction:column;align-items:center;justify-content:center;box-shadow:0 16px 40px #4f46e566;font-weight:800;transition:.25s}.back-top:hover{transform:translateY(-5px)}.back-top span{font:700 7px ui-monospace,monospace;letter-spacing:.12em}@keyframes spin{to{transform:rotate(360deg)}}@keyframes portraitFloat{50%{transform:translateY(-10px)}}@keyframes softFloat{50%{transform:translateY(-8px)}}@keyframes companyFloat{50%{transform:translateY(-7px)}}@keyframes certFloat{50%{margin-top:-10px}}@media(prefers-reduced-motion:reduce){*{animation:none!important;scroll-behavior:auto!important}}@media(max-width:900px){.hero,.credential-layout,.resume-inner{grid-template-columns:1fr}.grid,.contact-grid{grid-template-columns:1fr}.heading{align-items:start;flex-direction:column}.about{grid-template-columns:1fr}.navlinks a:nth-child(-n+3){display:none}.cert-cloud{height:auto;display:grid;grid-template-columns:1fr 1fr;gap:14px}.cert{position:relative;width:auto;inset:auto!important;transform:none!important}}@media(max-width:600px){.shell{width:calc(100% - 28px)}.navlinks{gap:10px}.navlinks a{font-size:9px}.hero{padding-top:70px}.hero h1{font-size:48px}.visual{height:450px}.portrait-wrap{width:250px;height:335px}.one{width:340px;height:340px}.two{width:260px;height:260px}.card{display:none}.companies{grid-template-columns:1fr;gap:12px}.company{padding:16px}.cert-cloud{grid-template-columns:1fr}.about{display:block}footer{flex-direction:column;gap:18px}footer div{flex-wrap:wrap}.back-top{right:16px;bottom:16px;width:52px;height:52px}}
</style>