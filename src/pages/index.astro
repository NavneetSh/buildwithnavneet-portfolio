---
import { profile, proofPoints, expertise, projects, companies, certifications, collaboration } from '../data/portfolio';
---
<!doctype html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width"><meta name="description" content={`${profile.name} — ${profile.role}. Cloud, platform engineering and AI infrastructure.`}><title>{profile.name} | {profile.role}</title></head><body>
<header><nav class="shell"><a class="brand" href="/"><span>N</span><b>{profile.name}</b></a><div class="navlinks"><a href="#services">Work together</a><a href="#work">Work</a><a href="#credentials">Credentials</a><a href="#resume">Resume</a><a href={profile.blogUrl}>Blog ↗</a></div></nav></header>
<main>
<section class="hero shell"><div><p class="eyebrow">{profile.eyebrow}</p><h1>{profile.headline}</h1><p class="lead">{profile.intro}</p><div class="actions"><a class="primary" href="#services">Work with me <span>↘</span></a><a class="secondary" href="#work">Explore my work <span>→</span></a></div><div class="proof">{proofPoints.map((item)=><span><b>{item.value}</b>{item.label}</span>)}</div></div><div class="visual"><div class="orbit one"></div><div class="orbit two"></div><div class="portrait-wrap"><img src="/images/navneet-profile.jpg" alt="Navneet Sharma, Cloud and AI Platform Architect" /></div><div class="card c1"><small>ARCHITECTURE</small><b>Systems that scale</b></div><div class="card c2"><small>DIRECTION</small><b>Cloud → AI platforms</b></div></div></section>
<section class="trust"><div class="shell"><p>EXPERIENCE SHAPED ACROSS</p><div class="companies">{companies.map((company)=><div><strong>{company.name}</strong><small>{company.context}</small></div>)}</div></div></section>
<section id="services" class="section shell"><div class="heading"><div><p class="eyebrow">WAYS I CAN HELP</p><h2>Senior technical thinking,<br>applied to hard problems.</h2></div><p>For teams that need clarity before complexity: architecture decisions, platform foundations and hands-on technical collaboration.</p></div><div class="grid">{collaboration.map((item,index)=><article class="expert"><span class="plus">0{index+1}</span><h3>{item.title}</h3><p>{item.description}</p><small>EXPLORE A CONVERSATION →</small></article>)}</div></section>
<section id="expertise" class="section soft shell"><div class="heading"><div><p class="eyebrow">TECHNICAL DEPTH</p><h2>Engineering across the stack.</h2></div><p>I work where infrastructure, developer experience and emerging AI systems meet.</p></div><div class="grid">{expertise.map((item)=><article class="expert"><span class="plus">+</span><h3>{item.title}</h3><p>{item.description}</p><small>{item.tags}</small></article>)}</div></section>
<section id="work" class="work"><div class="shell"><div class="heading light"><div><p class="eyebrow">SELECTED WORK</p><h2>Architecture with a reason.</h2></div><p>Platform and infrastructure work framed around the problem, the decisions and the engineering outcome.</p></div><div class="grid">{projects.map((project)=><article class="project"><div class="projecttop"><span>{project.number}</span><small>CASE STUDY</small></div><div class="art">{project.number}</div><h3>{project.title}</h3><p>{project.description}</p><small>{project.tags}</small></article>)}</div></div></section>
<section id="credentials" class="credentials"><div class="shell credential-layout"><div><p class="eyebrow">MICROSOFT CREDENTIALS</p><h2>Validated foundations.<br><em>Applied in practice.</em></h2><p>Credentials across architecture, cloud operations, security and DevOps reinforce a broader career built around production platforms.</p></div><div class="cert-cloud">{certifications.map((cert,index)=><article class={`cert cert-${index+1}`}><div class="ms"><i></i><i></i><i></i><i></i></div><small>{cert.focus}</small><strong>{cert.code}</strong><span>{cert.label}</span></article>)}</div></div></section>
<section id="resume" class="resume"><div class="shell resume-inner"><div><p class="eyebrow">PUBLIC PROFESSIONAL PROFILE</p><h2>Take the complete story<br><em>with you.</em></h2><p>Download my privacy-conscious PDF resume for a concise reference to my architecture background, technical capabilities and selected experience.</p></div><a class="download" href={profile.resumeUrl} download><span><small>PDF DOCUMENT</small><b>Download public resume</b></span><strong>↓</strong></a></div></section>
<section class="about shell"><p class="eyebrow">ABOUT</p><div><h2>Learning the future<br>by <em>building it.</em></h2><p>{profile.about}</p></div><a href={profile.blogUrl}>Read BuildWithNavneet →</a></section>
<section class="cta"><div class="shell"><p class="eyebrow">CLIENTS · COLLABORATORS · BUILDERS</p><h2>Have a difficult platform problem<br>or an ambitious idea?</h2><div class="actions"><a class="primary" href={profile.blogUrl}>Start with my work <span>→</span></a><a class="secondary dark" href={profile.resumeUrl}>View my profile <span>↗</span></a></div></div></section>
</main><footer class="shell"><span>© {new Date().getFullYear()} {profile.name}</span><span>Cloud · Platform Engineering · AI Infrastructure</span></footer>
</body></html>
<style is:global>
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:#fff;color:#0f172a;font-family:Inter,ui-sans-serif,system-ui,-apple-system,sans-serif}.shell{width:min(1180px,calc(100% - 48px));margin:auto}header{position:sticky;top:0;z-index:20;background:rgba(255,255,255,.88);backdrop-filter:blur(18px);border-bottom:1px solid #e2e8f0}nav{height:72px;display:flex;align-items:center;justify-content:space-between}.brand{display:flex;align-items:center;gap:10px;color:#111827;text-decoration:none;font-size:14px}.brand span{width:34px;height:34px;border-radius:50%;display:grid;place-items:center;background:#111827;color:#fff;font:700 17px Georgia}.navlinks{display:flex;gap:24px}.navlinks a{color:#64748b;text-decoration:none;font-size:12px;font-weight:700}.navlinks a:hover{color:#4f46e5}.hero{min-height:760px;display:grid;grid-template-columns:1.15fr .85fr;align-items:center;gap:70px;padding:75px 0 90px}.eyebrow{font:700 10px ui-monospace,SFMono-Regular,monospace;letter-spacing:.17em;color:#64748b;margin:0 0 24px}.eyebrow:before{content:'';display:inline-block;width:28px;height:1px;background:#4f46e5;vertical-align:middle;margin-right:10px}.hero h1,.heading h2,.about h2,.resume h2,.credentials h2,.cta h2{font-family:Georgia,'Times New Roman',serif;letter-spacing:-.045em}.hero h1{font-size:clamp(54px,6.5vw,88px);line-height:.97;margin:0;font-weight:500;max-width:760px}.lead{font-size:18px;line-height:1.75;max-width:690px;color:#64748b;margin:32px 0}.actions{display:flex;gap:12px;flex-wrap:wrap}.actions a{display:inline-flex;align-items:center;gap:28px;padding:15px 20px;border-radius:6px;text-decoration:none;font-size:13px;font-weight:750}.primary{background:#4f46e5;color:#fff}.secondary{border:1px solid #cbd5e1;color:#334155}.proof{display:flex;gap:34px;margin-top:52px;padding-top:24px;border-top:1px solid #e2e8f0;font-size:11px;color:#94a3b8}.proof span{display:flex;flex-direction:column;gap:4px}.proof b{color:#334155;font-size:14px}.visual{height:530px;position:relative;display:grid;place-items:center;background:radial-gradient(circle,rgba(79,70,229,.14),transparent 58%)}.orbit{position:absolute;border:1px solid #cbd5e1;border-radius:50%;animation:spin 22s linear infinite}.one{width:410px;height:410px}.two{width:315px;height:315px;animation-direction:reverse;animation-duration:16s}.orbit:after{content:'';position:absolute;width:8px;height:8px;border-radius:50%;background:#4f46e5;top:13%;left:12%;box-shadow:0 0 24px #818cf8}.portrait-wrap{position:relative;width:300px;height:380px;border-radius:150px 150px 30px 30px;overflow:hidden;box-shadow:0 35px 90px rgba(15,23,42,.28);animation:float 6s ease-in-out infinite;background:#111827}.portrait-wrap img{width:100%;height:100%;object-fit:cover;object-position:center 20%;transform:scale(1.04)}.card{position:absolute;background:rgba(255,255,255,.92);backdrop-filter:blur(12px);border:1px solid #e2e8f0;padding:16px 18px;box-shadow:0 18px 50px rgba(15,23,42,.12);display:flex;flex-direction:column;z-index:2}.card small{font-size:8px;letter-spacing:.14em;color:#94a3b8}.card b{font-size:12px}.c1{top:72px;right:-20px}.c2{bottom:65px;left:-25px}.trust{border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0;padding:34px 0;background:#fafafa}.trust p{text-align:center;font:700 9px ui-monospace,monospace;letter-spacing:.2em;color:#94a3b8;margin:0 0 25px}.companies{display:grid;grid-template-columns:repeat(3,1fr)}.companies div{text-align:center;border-right:1px solid #e2e8f0}.companies div:last-child{border:0}.companies strong{display:block;font-size:22px;letter-spacing:-.04em;color:#334155}.companies small{font-size:10px;color:#94a3b8}.section{padding:110px 0 125px}.soft{background:#fafbff}.heading{display:flex;justify-content:space-between;align-items:end;gap:50px;margin-bottom:55px}.heading h2{font-size:clamp(40px,5vw,62px);font-weight:500;margin:0}.heading>p{max-width:420px;color:#64748b;line-height:1.7}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.expert{border:1px solid #e2e8f0;padding:34px;min-height:290px;background:#fff;transition:.25s}.expert:hover{transform:translateY(-6px);box-shadow:0 25px 70px rgba(15,23,42,.09);border-color:#c7d2fe}.plus{font:700 13px ui-monospace,monospace;color:#4f46e5;display:block;margin-bottom:55px}.expert h3,.project h3{font-size:21px;margin:0 0 12px}.expert p,.project p{font-size:14px;line-height:1.75;color:#64748b}.expert small,.project small{font:700 9px ui-monospace,monospace;color:#64748b;letter-spacing:.05em}.work{background:#0b1120;padding:120px 0;color:#fff}.light h2{color:#fff}.light>p,.light .eyebrow{color:#94a3b8}.project{border:1px solid #253047;padding:24px;background:#101827}.projecttop{display:flex;justify-content:space-between;color:#64748b}.projecttop small{color:#818cf8}.art{height:180px;margin:22px 0 28px;background:linear-gradient(135deg,#172033,#111827);display:grid;place-items:center;font:500 100px Georgia;color:#202c43}.project h3{color:#fff}.project p{color:#94a3b8}.credentials{padding:125px 0;background:#f7f7fb;overflow:hidden}.credential-layout{display:grid;grid-template-columns:.75fr 1.25fr;gap:70px;align-items:center}.credentials h2{font-size:clamp(44px,5vw,66px);line-height:1.03;font-weight:500;margin:0 0 25px}.credentials h2 em,.resume h2 em,.about h2 em{color:#4f46e5;font-weight:400}.credentials>div>div>p{color:#64748b;line-height:1.8}.cert-cloud{height:500px;position:relative}.cert{position:absolute;width:245px;background:#fff;border:1px solid #e2e8f0;padding:24px;box-shadow:0 24px 70px rgba(15,23,42,.1);display:flex;flex-direction:column;transition:.25s}.cert:hover{transform:translateY(-7px)!important;border-color:#818cf8}.cert small{font:700 8px ui-monospace,monospace;letter-spacing:.15em;color:#94a3b8;margin:18px 0 7px}.cert strong{font-size:31px;letter-spacing:-.05em}.cert span{font-size:11px;color:#64748b;margin-top:4px}.cert-1{top:0;left:5%;transform:rotate(-4deg)}.cert-2{top:55px;right:2%;transform:rotate(4deg)}.cert-3{bottom:25px;left:0;transform:rotate(3deg)}.cert-4{bottom:0;right:8%;transform:rotate(-3deg)}.ms{width:28px;height:28px;display:grid;grid-template-columns:1fr 1fr;gap:2px}.ms i{background:#4f46e5}.ms i:nth-child(2){opacity:.8}.ms i:nth-child(3){opacity:.65}.ms i:nth-child(4){opacity:.5}.resume{background:#eef2ff;padding:100px 0;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0}.resume-inner{display:grid;grid-template-columns:1.3fr .7fr;align-items:center;gap:80px}.resume h2{font-size:clamp(42px,5vw,64px);line-height:1.03;font-weight:500;margin:0 0 24px}.resume p{max-width:650px;color:#64748b;font-size:16px;line-height:1.8}.download{background:#fff;border:1px solid #dbe2f0;padding:28px;display:flex;align-items:center;justify-content:space-between;text-decoration:none;color:#0f172a;box-shadow:0 18px 50px rgba(15,23,42,.08);transition:.25s}.download:hover{transform:translateY(-4px);border-color:#4f46e5}.download span{display:flex;flex-direction:column;gap:7px}.download small{font:700 9px ui-monospace,monospace;letter-spacing:.14em;color:#818cf8}.download b{font-size:16px}.download strong{font-size:30px;color:#4f46e5}.about{padding:130px 0;display:grid;grid-template-columns:.5fr 1.4fr .5fr;gap:40px;align-items:start}.about h2{font-size:clamp(44px,5vw,66px);line-height:1.05;font-weight:500;margin:0}.about div p{max-width:650px;color:#64748b;font-size:17px;line-height:1.8}.about>a{color:#334155;text-decoration:none;font-weight:700;font-size:13px;justify-self:end;border-bottom:1px solid #cbd5e1;padding-bottom:8px}.cta{padding:120px 0;background:#0b1120;color:#fff;text-align:center}.cta .eyebrow{color:#94a3b8}.cta h2{font-size:clamp(46px,6vw,76px);line-height:1.03;font-weight:500;margin:0 auto 38px}.cta .actions{justify-content:center}.dark{color:#fff;border-color:#475569}footer{border-top:1px solid #e2e8f0;padding:30px 0 45px;display:flex;justify-content:space-between;color:#94a3b8;font-size:12px}@keyframes spin{to{transform:rotate(360deg)}}@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}@media(prefers-reduced-motion:reduce){*{scroll-behavior:auto!important}.orbit,.portrait-wrap{animation:none!important}}@media(max-width:900px){.hero,.credential-layout{grid-template-columns:1fr}.hero{min-height:auto;padding-top:100px}.visual{height:500px}.grid,.resume-inner{grid-template-columns:1fr}.heading{align-items:start;flex-direction:column}.about{grid-template-columns:1fr}.about>a{justify-self:start}.proof{flex-wrap:wrap}.cert-cloud{margin-top:20px}.navlinks a:first-child{display:none}}@media(max-width:600px){.shell{width:calc(100% - 28px)}.navlinks{gap:10px}.navlinks a{font-size:9px}.navlinks a:nth-child(3){display:none}.hero{padding-top:70px;gap:20px}.hero h1{font-size:48px}.visual{height:430px}.one{width:330px;height:330px}.two{width:250px;height:250px}.portrait-wrap{width:240px;height:315px}.card{display:none}.section,.work,.about,.resume,.credentials,.cta{padding-top:80px;padding-bottom:80px}.expert{min-height:auto}.companies strong{font-size:15px}.companies small{font-size:8px}.credential-layout{gap:20px}.cert-cloud{height:auto;display:grid;grid-template-columns:1fr 1fr;gap:10px}.cert{position:relative!important;width:auto;inset:auto!important;transform:none!important;padding:18px}.cert strong{font-size:24px}footer{gap:20px;flex-direction:column}}
</style>