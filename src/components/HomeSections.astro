---
import { profile, expertise, projects, companies, certifications, collaboration } from '../data/portfolio';
const emailHref = `mailto:${profile.email}?subject=Let%27s%20work%20together`;
---
<!-- Experience / company trust strip -->
<section class="trust"><div class="shell"><p class="center-label">EXPERIENCE SHAPED ACROSS</p><div class="companies">{companies.map((company,index)=><div class={`company company-${index+1}`}><strong>{company.name}</strong><small>{company.context}</small></div>)}</div></div></section>

<!-- Collaboration services -->
<section id="services" class="section shell"><div class="heading"><div><p class="eyebrow">WAYS I CAN HELP</p><h2>Senior technical thinking,<br />applied to hard problems.</h2></div><p>For teams that need clarity before complexity: architecture decisions, platform foundations and hands-on technical collaboration.</p></div><div class="grid">{collaboration.map((item,index)=><article class="expert"><span class="plus">0{index+1}</span><h3>{item.title}</h3><p>{item.description}</p><a href={emailHref}>START A CONVERSATION →</a></article>)}</div></section>

<!-- Technical expertise -->
<section class="section soft"><div class="shell"><div class="heading"><div><p class="eyebrow">TECHNICAL DEPTH</p><h2>Engineering across the stack.</h2></div><p>I work where infrastructure, developer experience and emerging AI systems meet.</p></div><div class="grid">{expertise.map(item=><article class="expert"><span class="plus">+</span><h3>{item.title}</h3><p>{item.description}</p><small>{item.tags}</small></article>)}</div></div></section>

<!-- Selected case-study cards -->
<section id="work" class="work"><div class="shell"><div class="heading light"><div><p class="eyebrow">SELECTED WORK</p><h2>Architecture with a reason.</h2></div><p>Platform and infrastructure work framed around the problem, the decisions and the engineering outcome.</p></div><div class="grid">{projects.map(project=><article class="project"><div class="projecttop"><span>{project.number}</span><small>CASE STUDY</small></div><div class="art">{project.number}</div><h3>{project.title}</h3><p>{project.description}</p><small>{project.tags}</small></article>)}</div></div></section>

<!-- Microsoft credentials -->
<section id="credentials" class="credentials"><div class="shell credential-layout"><div><p class="eyebrow">MICROSOFT CREDENTIALS</p><h2>Validated foundations.<br /><em>Applied in practice.</em></h2><p>Credentials across architecture, cloud operations, security and DevOps reinforce a broader career built around production platforms.</p></div><div class="cert-cloud">{certifications.map((cert,index)=><article class={`cert cert-${index+1}`}><div class="ms"><i></i><i></i><i></i><i></i></div><small>{cert.focus}</small><strong>{cert.code}</strong><span>{cert.label}</span></article>)}</div></div></section>

<!-- Resume / professional profile download -->
<section id="resume" class="resume"><div class="shell resume-inner"><div><p class="eyebrow">PROFESSIONAL CREDENTIALS</p><h2>Explore my professional<br /><em>profile.</em></h2><p>A curated overview of my architecture experience, technical capabilities, certifications and selected work.</p></div><a class="download" href={profile.resumeUrl} download><span class="download-copy"><small>PROFESSIONAL PROFILE</small><b>View career credentials</b></span><strong class="download-icon">↓</strong></a></div></section>

<!-- Personal positioning and blog link -->
<section class="about shell"><p class="eyebrow">ABOUT</p><div><h2>Learning the future<br />by <em>building it.</em></h2><p>{profile.about}</p></div><a href={profile.blogUrl}>Read BuildWithNavneet →</a></section>

<!-- Contact channels -->
<section id="contact" class="contact"><div class="shell"><p class="eyebrow">LET'S CONNECT</p><h2>Have a difficult platform problem<br />or an ambitious idea?</h2><p class="contact-lead">I’m open to architecture conversations, technical collaborations and selected opportunities.</p><div class="contact-grid"><a href={emailHref}><small>EMAIL</small><strong>{profile.email}</strong><span>Start a conversation ↗</span></a><a href={profile.blogUrl}><small>BLOG</small><strong>BuildWithNavneet</strong><span>Read what I’m learning and building ↗</span></a><a href={profile.portfolioUrl}><small>PORTFOLIO</small><strong>Professional profile</strong><span>Share this portfolio ↗</span></a></div></div></section>
